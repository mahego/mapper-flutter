# Google Places API Configuration
# Obtener API key en: https://console.cloud.google.com/
# Habilitar: Places API, Maps JavaScript API, Geocoding API
GOOGLE_PLACES_API_KEY=

# Mapbox Configuration (alternativa a Google Places)
# Obtener token en: https://account.mapbox.com/auth/signup/
MAPBOX_ACCESS_TOKEN=pk.your_actual_token_here

# Backend API (opcional, si es diferente al hardcoded)
# API_BASE_URL=https://api.example.com/api

# Environment
# ENVIRONMENT=development|production
